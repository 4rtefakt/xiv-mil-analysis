{
  "name": "xiv-mil-analysis",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "FFXIV log analyzer that scales its analysis to each player's synced level, not a hardcoded level cap.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "probe": "tsx src/scripts/probe.ts",
    "analyse": "tsx src/scripts/analyse.ts",
    "debug-events": "tsx src/scripts/debug-events.ts",
    "server": "tsx watch server/index.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
