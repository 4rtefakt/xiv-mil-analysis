# Copy this file to `.env` and fill in your FFLogs API client credentials.
# `.env` is gitignored — it stays on your machine and is never committed.
# Create a client at https://www.fflogs.com/api/clients (keep "Public Client" unchecked).
FFLOGS_CLIENT_ID=your_client_id_here
FFLOGS_CLIENT_SECRET=your_client_secret_here
